# Cổng chạy server (mặc định 3000 nếu bỏ trống)
PORT=3000

# Phiên bản Facebook Graph API, ví dụ: v21.0
GRAPH_API_VERSION=v21.0

# ID của Fanpage Facebook cần quản lý
PAGE_ID=

# Page Access Token (lấy từ Meta for Developers hoặc Graph API Explorer)
PAGE_ACCESS_TOKEN=

# App ID của ứng dụng Facebook đã tạo trên Meta for Developers
APP_ID=

# App Secret tương ứng với App ID ở trên
APP_SECRET=

# ==================== AI Agent trả lời & chốt khách trên Messenger ====================

# API key Claude, lấy tại console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Model Claude dùng để trả lời khách (để trống sẽ dùng mặc định claude-sonnet-5)
ANTHROPIC_MODEL=

# Chuỗi bạn tự đặt (bất kỳ, càng khó đoán càng tốt) — dùng khi khai báo Webhook
# trên Meta for Developers ở bước "Verify Token"
FB_VERIFY_TOKEN=

# ==================== Học viện Tự Do Thịnh Vượng / Đậu Ánh AI ====================

# Project URL của Supabase, dạng https://xxxx.supabase.co (Project Settings > API)
SUPABASE_URL=

# anon public key (Project Settings > API) - an toàn để lộ ra frontend
SUPABASE_ANON_KEY=

# service_role key (Project Settings > API) - TUYỆT ĐỐI KHÔNG lộ ra frontend,
# chỉ dùng ở server để xác nhận đơn hàng/mở khoá khoá học
SUPABASE_SERVICE_ROLE_KEY=

# Mật khẩu đơn giản để vào trang quản trị xác nhận đơn hàng (public/hoc-vien/admin.html)
ADMIN_PASSCODE=

# Thông tin tài khoản ngân hàng hiển thị cho học viên khi chuyển khoản
BANK_NAME=
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_HOLDER=
